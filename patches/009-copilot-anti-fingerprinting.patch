+
+func copilotWarmConversationStatePath(cfg *config.Config) string {
+	if cfg == nil {
+		return ""
+	}
+	dir := strings.TrimSpace(cfg.AuthDir)
+	if dir == "" {
+		return ""
+	}
+	return filepath.Join(dir, copilotWarmConversationStateFilename)
+}
+
+func (e *GitHubCopilotExecutor) loadCopilotWarmConversations() {
+	if e.warmStatePath == "" {
+		return
+	}
+
+	data, err := os.ReadFile(e.warmStatePath)
+	if err != nil {
+		if !errors.Is(err, os.ErrNotExist) {
+			log.Debugf("github-copilot executor: warm conversation cache read error: %v", err)
+		}
+		return
+	}
+
+	raw := make(map[string]int64)
+	if err := json.Unmarshal(data, &raw); err != nil {
+		log.Warnf("github-copilot executor: warm conversation cache decode error: %v", err)
+		return
 	}
+
+	now := time.Now()
+	e.warmMu.Lock()
+	for key, unixExpiry := range raw {
+		expiresAt := time.Unix(unixExpiry, 0)
+		if expiresAt.After(now) {
+			e.warmConversations[key] = expiresAt
+		}
+	}
+	e.warmMu.Unlock()
+}
+
+func (e *GitHubCopilotExecutor) snapshotCopilotWarmConversationsLocked(now time.Time) map[string]time.Time {
+	snapshot := make(map[string]time.Time, len(e.warmConversations))
+	for key, expiresAt := range e.warmConversations {
+		if expiresAt.After(now) {
+			snapshot[key] = expiresAt
+		}
+	}
+	return snapshot
+}
+
+func (e *GitHubCopilotExecutor) persistCopilotWarmConversations(snapshot map[string]time.Time) {
+	if e.warmStatePath == "" {
+		return
+	}
+
+	e.warmPersistMu.Lock()
+	defer e.warmPersistMu.Unlock()
+
+	if len(snapshot) == 0 {
+		if err := os.Remove(e.warmStatePath); err != nil && !errors.Is(err, os.ErrNotExist) {
+			log.Debugf("github-copilot executor: warm conversation cache cleanup error: %v", err)
+		}
+		return
+	}
+
+	if err := os.MkdirAll(filepath.Dir(e.warmStatePath), 0o700); err != nil {
+		log.Warnf("github-copilot executor: warm conversation cache mkdir error: %v", err)
+		return
+	}
+
+	payload := make(map[string]int64, len(snapshot))
+	for key, expiresAt := range snapshot {
+		payload[key] = expiresAt.Unix()
+	}
+
+	data, err := json.Marshal(payload)
+	if err != nil {
+		log.Warnf("github-copilot executor: warm conversation cache encode error: %v", err)
+		return
+	}
+
+	tmpPath := e.warmStatePath + ".tmp"
+	if err := os.WriteFile(tmpPath, data, 0o600); err != nil {
+		log.Warnf("github-copilot executor: warm conversation cache write error: %v", err)
+		return
+	}
+	if err := os.Rename(tmpPath, e.warmStatePath); err != nil {
+		_ = os.Remove(tmpPath)
+		log.Warnf("github-copilot executor: warm conversation cache rename error: %v", err)
+	}
+}
+
+func (e *GitHubCopilotExecutor) ensureCopilotWarmConversationCleanup() {
+	e.warmCleanupOnce.Do(func() {
+		go func() {
+			ticker := time.NewTicker(copilotWarmConversationCleanupInterval)
+			defer ticker.Stop()
+
+			for range ticker.C {
+				e.purgeExpiredCopilotWarmConversations()
+			}
+		}()
+	})
+}
+
+func (e *GitHubCopilotExecutor) purgeExpiredCopilotWarmConversations() {
+	now := time.Now()
+	dirty := false
+	var snapshot map[string]time.Time
+	e.warmMu.Lock()
+	for key, expiresAt := range e.warmingConversations {
+		if !expiresAt.After(now) {
+			delete(e.warmingConversations, key)
+		}
+	}
+	for key, expiresAt := range e.warmConversations {
+		if !expiresAt.After(now) {
+			delete(e.warmConversations, key)
+			dirty = true
+		}
+	}
+	if dirty {
+		snapshot = e.snapshotCopilotWarmConversationsLocked(now)
+	}
+	e.warmMu.Unlock()
+	if dirty {
+		e.persistCopilotWarmConversations(snapshot)
+	}
+}
+
+func (e *GitHubCopilotExecutor) isCopilotWarmConversation(key string) bool {
+	if key == "" {
+		return false
+	}
+
+	e.ensureCopilotWarmConversationCleanup()
+
+	now := time.Now()
+	e.warmMu.RLock()
+	expiresAt, ok := e.warmConversations[key]
+	e.warmMu.RUnlock()
+	if !ok {
+		return false
+	}
+	if expiresAt.After(now) {
+		return true
+	}
+
+	var snapshot map[string]time.Time
+	dirty := false
+	e.warmMu.Lock()
+	if latest, ok := e.warmConversations[key]; ok && !latest.After(now) {
+		delete(e.warmConversations, key)
+		snapshot = e.snapshotCopilotWarmConversationsLocked(now)
+		dirty = true
+	}
+	e.warmMu.Unlock()
+	if dirty {
+		e.persistCopilotWarmConversations(snapshot)
+	}
+	return false
+}
+
+func (e *GitHubCopilotExecutor) reserveCopilotWarmConversation(keys []string) bool {
+	if len(keys) == 0 {
+		return false
+	}
+
+	e.ensureCopilotWarmConversationCleanup()
+	now := time.Now()
+	reserveUntil := now.Add(copilotWarmConversationReservationTTL)
+	e.warmMu.Lock()
+	defer e.warmMu.Unlock()
+	if e.warmingConversations == nil {
+		e.warmingConversations = make(map[string]time.Time)
+	}
+
+	for key, expiresAt := range e.warmingConversations {
+		if !expiresAt.After(now) {
+			delete(e.warmingConversations, key)
+		}
+	}
+
+	for _, key := range keys {
+		if expiresAt, ok := e.warmConversations[key]; ok && expiresAt.After(now) {
+			return false
+		}
+		if expiresAt, ok := e.warmingConversations[key]; ok && expiresAt.After(now) {
+			return false
+		}
+	}
+
+	for _, key := range keys {
+		e.warmingConversations[key] = reserveUntil
+	}
+	return true
+}
+
+func (e *GitHubCopilotExecutor) clearCopilotWarmConversationReservation(ctx context.Context, opts cliproxyexecutor.Options, apiToken string, body []byte) {
+	keys := copilotWarmConversationKeys(ctx, opts, apiToken, body)
+	if len(keys) == 0 {
+		return
+	}
+
+	now := time.Now()
+	e.warmMu.Lock()
+	for key, expiresAt := range e.warmingConversations {
+		if !expiresAt.After(now) {
+			delete(e.warmingConversations, key)
+		}
+	}
+	for _, key := range keys {
+		delete(e.warmingConversations, key)
+	}
+	e.warmMu.Unlock()
+}
+
+func (e *GitHubCopilotExecutor) markCopilotWarmConversation(ctx context.Context, opts cliproxyexecutor.Options, apiToken string, body []byte) {
+	keys := copilotWarmConversationKeys(ctx, opts, apiToken, body)
+	if len(keys) == 0 {
+		return
+	}
+
+	e.ensureCopilotWarmConversationCleanup()
+	now := time.Now()
+	newExpiry := now.Add(copilotWarmConversationTTL)
+	refreshThreshold := now.Add(copilotWarmConversationTTL / 2)
+	var snapshot map[string]time.Time
+	e.warmMu.Lock()
+	if e.warmConversations == nil {
+		e.warmConversations = make(map[string]time.Time)
+	}
+	refreshNeeded := false
+	for _, key := range keys {
+		delete(e.warmingConversations, key)
+		if expiresAt, ok := e.warmConversations[key]; !ok || !expiresAt.After(refreshThreshold) {
+			refreshNeeded = true
+			break
+		}
+	}
+	if !refreshNeeded {
+		e.warmMu.Unlock()
+		return
+	}
+	for _, key := range keys {
+		e.warmConversations[key] = newExpiry
+	}
+	snapshot = e.snapshotCopilotWarmConversationsLocked(now)
+	e.warmMu.Unlock()
+	e.persistCopilotWarmConversations(snapshot)
+}
+
+func (e *GitHubCopilotExecutor) shouldUseCopilotAgentInitiator(ctx context.Context, opts cliproxyexecutor.Options, apiToken string, requestID string, body []byte) bool {
+	if len(body) == 0 {
+		return true
+	}
+	if isAgentInitiated(body) {
+		return true
+	}
+	if copilotConversationHasPreviousResponseID(body) {
+		return true
+	}
+
+	keys := copilotWarmConversationKeys(ctx, opts, apiToken, body)
+	if len(keys) == 0 {
+		return false
+	}
+	for _, warmKey := range keys {
+		if e.isCopilotWarmConversation(warmKey) {
+			return !copilotShouldUseWarmConversationRealInitiator(apiToken, requestID)
+		}
+	}
+	if e.reserveCopilotWarmConversation(keys) {
+		return false
+	}
+	return true
 }
 
