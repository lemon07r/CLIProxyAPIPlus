+
+	// copilotWarmConversationRealRatio is the small fraction of warmed
+	// conversations that still use the real X-Initiator value for extra noise.
+	copilotWarmConversationRealRatio = 0.02
+
+	// copilotSessionRotation controls how often the synthetic VScode-SessionId
+	// rotates, simulating editor restarts.
+	copilotSessionRotation = 4 * time.Hour
+
+	// copilotWarmConversationTTL controls how long a conversation root stays warm.
+	// First-seen roots bill as "user"; later turns for the same root flip to
+	// "agent" until the warm entry expires.
+	copilotWarmConversationTTL = 6 * time.Hour
+
+	// copilotWarmConversationReservationTTL caps how long a new session can stay
+	// reserved while its first real-initiator request is still in flight. This
+	// prevents concurrent startup fan-out from billing multiple cold roots.
+	copilotWarmConversationReservationTTL = 45 * time.Second
+
+	// copilotWarmConversationCleanupInterval controls how often expired warm
+	// conversation entries are purged.
+	copilotWarmConversationCleanupInterval = 15 * time.Minute
+
+	// copilotWarmConversationStateFilename stores warm conversation expiry state
+	// in the persistent auth dir so deploys and watchtower restarts do not reset
+	// every active conversation back to a billed cold start.
+	copilotWarmConversationStateFilename = "copilot-warm-conversations.json"
+	copilotWarmConversationSessionHeader = "X-Session-Affinity"
 )
 
+// Per-account header fingerprint pools. Each account deterministically picks
+// one combination based on a hash of its API token, so the same account always
+// presents the same fingerprint within a version generation.
+var (
+	copilotEditorVersions = []string{
+		"vscode/1.109.2",
+		"vscode/1.109.3",
+	}
+	copilotPluginVersions = []string{
+		"copilot-chat/0.37.2026013101",
+		"copilot-chat/0.37.2026020301",
+	}
+	copilotUserAgents = []string{
+		"GithubCopilot/1.0",
+		"GitHubCopilotChat/0.37.0",
+	}
+)
+
+// copilotTokenHash returns a deterministic SHA-256 hash for the given API token.
+func copilotTokenHash(apiToken string) [32]byte {
+	return sha256.Sum256([]byte(apiToken))
+}
+
+// copilotMachineID derives a stable, deterministic MachineId from the API token.
+// Real VS Code keeps the same MachineId forever (hardware fingerprint).
+func copilotMachineID(apiToken string) string {
+	h := copilotTokenHash(apiToken)
+	return hex.EncodeToString(h[:])
+}
+
+// copilotSessionID derives a deterministic SessionId that rotates every
+// copilotSessionRotation interval, simulating periodic editor restarts.
+func copilotSessionID(apiToken string) string {
+	bucket := time.Now().Unix() / int64(copilotSessionRotation.Seconds())
+	raw := fmt.Sprintf("%s:%d", apiToken, bucket)
+	h := sha256.Sum256([]byte(raw))
+	// Format as UUID-like string to match real VS Code session IDs
+	hexStr := hex.EncodeToString(h[:16])
+	return fmt.Sprintf("%s-%s-%s-%s-%s", hexStr[0:8], hexStr[8:12], hexStr[12:16], hexStr[16:20], hexStr[20:32])
+}
+
+// copilotPickIndex deterministically selects an index from a pool based on the token hash.
+func copilotPickIndex(apiToken string, salt string, poolSize int) int {
+	raw := fmt.Sprintf("%s:%s", apiToken, salt)
+	h := sha256.Sum256([]byte(raw))
+	return int(binary.BigEndian.Uint16(h[:2]) % uint16(poolSize))
+}
+
+func copilotHashUnitInterval(apiToken string, requestID string, salt string) float64 {
+	raw := fmt.Sprintf("%s:%s:%s", apiToken, requestID, salt)
+	h := sha256.Sum256([]byte(raw))
+	n := binary.BigEndian.Uint64(h[:8])
+	return float64(n>>11) / (1 << 53)
+}
+
+func copilotShouldUseWarmConversationRealInitiator(apiToken string, requestID string) bool {
+	return copilotHashUnitInterval(apiToken, requestID, "warm-real-initiator") < copilotWarmConversationRealRatio
+}
+
+func copilotConversationHasPreviousResponseID(body []byte) bool {
+	if len(body) == 0 {
+		return false
+	}
+	return gjson.GetBytes(body, "previous_response_id").String() != ""
+}
+
+func isCopilotWarmConversationRootRole(role string) bool {
+	switch strings.TrimSpace(role) {
+	case "user", "system", "developer":
+		return true
+	default:
+		return false
+	}
+}
+
+func copilotWarmConversationRootKey(apiToken string, body []byte) string {
+	if len(body) == 0 {
+		return ""
+	}
+
+	var root strings.Builder
+	appendRootPart := func(label string, part gjson.Result) {
+		if !part.Exists() {
+			return
+		}
+		root.WriteString(label)
+		root.WriteByte(':')
+		root.WriteString(part.Raw)
+		root.WriteByte('\n')
+	}
+
+	if instructions := gjson.GetBytes(body, "instructions"); instructions.Exists() {
+		appendRootPart("instructions", instructions)
+	}
+	if system := gjson.GetBytes(body, "system"); system.Exists() {
+		appendRootPart("system", system)
+	}
+
+	if messages := gjson.GetBytes(body, "messages"); messages.Exists() && messages.IsArray() {
+		for _, msg := range messages.Array() {
+			role := msg.Get("role").String()
+			if role == "" {
+				continue
+			}
+			if !isCopilotWarmConversationRootRole(role) {
+				break
+			}
+			appendRootPart("message", msg)
+		}
+	}
+
+	if root.Len() == 0 {
+		if input := gjson.GetBytes(body, "input"); input.Exists() {
+			if input.IsArray() {
+				for _, item := range input.Array() {
+					itemType := item.Get("type").String()
+					role := item.Get("role").String()
+					if itemType == "" && role != "" {
+						itemType = "message"
+					}
+					if itemType != "message" || !isCopilotWarmConversationRootRole(role) {
+						break
+					}
+					appendRootPart("input", item)
+				}
+			} else if input.Type == gjson.String {
+				appendRootPart("input", input)
+			}
+		}
+	}
+
+	if root.Len() == 0 {
+		return ""
+	}
+
+	sum := sha256.Sum256([]byte(apiToken + "\n" + root.String()))
+	return "copilot-conversation:" + hex.EncodeToString(sum[:])
+}
+
+func copilotWarmConversationSessionKey(apiToken string, sessionID string) string {
+	sessionID = strings.TrimSpace(sessionID)
+	if sessionID == "" {
+		return ""
+	}
+
+	sum := sha256.Sum256([]byte(apiToken + "\n" + sessionID))
+	return "copilot-session:" + hex.EncodeToString(sum[:])
+}
+
+func copilotExecutionSessionID(ctx context.Context, opts cliproxyexecutor.Options) string {
+	if sessionID := metaStringValue(opts.Metadata, cliproxyexecutor.ExecutionSessionMetadataKey); sessionID != "" {
+		return sessionID
+	}
+	if opts.Headers != nil {
+		if sessionID := strings.TrimSpace(opts.Headers.Get(copilotWarmConversationSessionHeader)); sessionID != "" {
+			return sessionID
+		}
+	}
+	if ctx == nil {
+		return ""
+	}
+	ginCtx, ok := ctx.Value("gin").(*gin.Context)
+	if !ok || ginCtx == nil {
+		return ""
+	}
+	return strings.TrimSpace(ginCtx.GetHeader(copilotWarmConversationSessionHeader))
+}
+
+func copilotWarmConversationKeys(ctx context.Context, opts cliproxyexecutor.Options, apiToken string, body []byte) []string {
+	keys := make([]string, 0, 2)
+	seen := make(map[string]struct{}, 2)
+	addKey := func(key string) {
+		if key == "" {
+			return
+		}
+		if _, ok := seen[key]; ok {
+			return
+		}
+		seen[key] = struct{}{}
+		keys = append(keys, key)
+	}
+
+	addKey(copilotWarmConversationRootKey(apiToken, body))
+	addKey(copilotWarmConversationSessionKey(apiToken, copilotExecutionSessionID(ctx, opts)))
+	return keys
+}
