+func TestConvertOpenAIRequestToClaude_ParallelToolResultsMergedIntoSingleMessage(t *testing.T) {
+	inputJSON := `{
+		"model": "gpt-4.1",
+		"messages": [
+			{"role": "user", "content": "do both"},
+			{
+				"role": "assistant",
+				"content": "",
+				"tool_calls": [
+					{"id": "call_a", "type": "function", "function": {"name": "tool1", "arguments": "{}"}},
+					{"id": "call_b", "type": "function", "function": {"name": "tool2", "arguments": "{}"}}
+				]
+			},
+			{"role": "tool", "tool_call_id": "call_a", "content": "result_a"},
+			{"role": "tool", "tool_call_id": "call_b", "content": "result_b"}
+		]
+	}`
+
+	result := ConvertOpenAIRequestToClaude("claude-sonnet-4-5", []byte(inputJSON), false)
+	resultJSON := gjson.ParseBytes(result)
+	messages := resultJSON.Get("messages").Array()
+
+	// user, assistant (with 2 tool_use), user (with 2 tool_result)
+	if len(messages) != 3 {
+		t.Fatalf("Expected 3 messages, got %d. Messages: %s", len(messages), resultJSON.Get("messages").Raw)
+	}
+
+	toolResultMsg := messages[2]
+	if got := toolResultMsg.Get("role").String(); got != "user" {
+		t.Fatalf("Expected tool result message role %q, got %q", "user", got)
+	}
+	contentArr := toolResultMsg.Get("content").Array()
+	if len(contentArr) != 2 {
+		t.Fatalf("Expected 2 tool_result blocks in single message, got %d. Content: %s", len(contentArr), toolResultMsg.Get("content").Raw)
+	}
+	if got := contentArr[0].Get("tool_use_id").String(); got != "call_a" {
+		t.Fatalf("Expected first tool_use_id %q, got %q", "call_a", got)
+	}
+	if got := contentArr[1].Get("tool_use_id").String(); got != "call_b" {
+		t.Fatalf("Expected second tool_use_id %q, got %q", "call_b", got)
+	}
+}
