+func TestConvertOpenAIResponsesRequestToClaude_InsertsLateToolResultsBeforeUserText(t *testing.T) {
+	inputJSON := `{
+		"model": "gpt-5.4",
+		"input": [
+			{"type": "message", "role": "user", "content": [{"type": "input_text", "text": "Use the tool."}]},
+			{"type": "function_call", "call_id": "call_a", "name": "read", "arguments": "{}"},
+			{"type": "message", "role": "user", "content": [{"type": "input_text", "text": "Continue after the tool result."}]},
+			{"type": "function_call_output", "call_id": "call_a", "output": "ok"}
+		]
+	}`
+
+	result := ConvertOpenAIResponsesRequestToClaude("claude-sonnet-4-5", []byte(inputJSON), false)
+	resultJSON := gjson.ParseBytes(result)
+	messages := resultJSON.Get("messages").Array()
+
+	if len(messages) != 3 {
+		t.Fatalf("Expected 3 messages, got %d. Messages: %s", len(messages), resultJSON.Get("messages").Raw)
+	}
+
+	userMsg := messages[2]
+	userContent := userMsg.Get("content").Array()
+	if len(userContent) != 2 {
+		t.Fatalf("Expected 2 user content blocks, got %d. Content: %s", len(userContent), userMsg.Get("content").Raw)
+	}
+	if got := userContent[0].Get("type").String(); got != "tool_result" {
+		t.Fatalf("Expected user content[0].type %q, got %q", "tool_result", got)
+	}
+	if got := userContent[0].Get("tool_use_id").String(); got != "call_a" {
+		t.Fatalf("Expected tool_result id %q, got %q", "call_a", got)
+	}
+	if got := userContent[1].Get("type").String(); got != "text" {
+		t.Fatalf("Expected user content[1].type %q, got %q", "text", got)
+	}
+	if got := userContent[1].Get("text").String(); got != "Continue after the tool result." {
+		t.Fatalf("Expected trailing user text %q, got %q", "Continue after the tool result.", got)
+	}
+}
