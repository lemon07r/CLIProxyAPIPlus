+func TestConvertOpenAIResponsesRequestToClaude_MergesMixedAssistantAndUserTurnsAroundTools(t *testing.T) {
+	inputJSON := `{
+		"model": "gpt-5.4",
+		"input": [
+			{"type": "message", "role": "user", "content": [{"type": "input_text", "text": "Use both tools."}]},
+			{"type": "message", "role": "assistant", "content": [{"type": "output_text", "text": "I'll inspect both."}]},
+			{"type": "function_call", "call_id": "call_a", "name": "glob", "arguments": "{\"pattern\":\"*.go\"}"},
+			{"type": "function_call", "call_id": "call_b", "name": "read", "arguments": "{\"filePath\":\"README.md\"}"},
+			{"type": "function_call_output", "call_id": "call_a", "output": "glob result"},
+			{"type": "function_call_output", "call_id": "call_b", "output": "read result"},
+			{"type": "message", "role": "user", "content": [{"type": "input_text", "text": "Now summarize."}]}
+		]
+	}`
+
+	result := ConvertOpenAIResponsesRequestToClaude("claude-sonnet-4-5", []byte(inputJSON), false)
+	resultJSON := gjson.ParseBytes(result)
+	messages := resultJSON.Get("messages").Array()
+
+	if len(messages) != 3 {
+		t.Fatalf("Expected 3 messages, got %d. Messages: %s", len(messages), resultJSON.Get("messages").Raw)
+	}
+
+	assistantMsg := messages[1]
+	if got := assistantMsg.Get("role").String(); got != "assistant" {
+		t.Fatalf("Expected assistant role, got %q", got)
+	}
+	assistantContent := assistantMsg.Get("content").Array()
+	if len(assistantContent) != 3 {
+		t.Fatalf("Expected 3 assistant content blocks, got %d. Content: %s", len(assistantContent), assistantMsg.Get("content").Raw)
+	}
+	if got := assistantContent[0].Get("type").String(); got != "text" {
+		t.Fatalf("Expected assistant content[0].type %q, got %q", "text", got)
+	}
+	if got := assistantContent[0].Get("text").String(); got != "I'll inspect both." {
+		t.Fatalf("Expected assistant text %q, got %q", "I'll inspect both.", got)
+	}
+	if got := assistantContent[1].Get("type").String(); got != "tool_use" {
+		t.Fatalf("Expected assistant content[1].type %q, got %q", "tool_use", got)
+	}
+	if got := assistantContent[1].Get("id").String(); got != "call_a" {
+		t.Fatalf("Expected first tool_use id %q, got %q", "call_a", got)
+	}
+	if got := assistantContent[2].Get("type").String(); got != "tool_use" {
+		t.Fatalf("Expected assistant content[2].type %q, got %q", "tool_use", got)
+	}
+	if got := assistantContent[2].Get("id").String(); got != "call_b" {
+		t.Fatalf("Expected second tool_use id %q, got %q", "call_b", got)
+	}
+
+	userMsg := messages[2]
+	if got := userMsg.Get("role").String(); got != "user" {
+		t.Fatalf("Expected user role, got %q", got)
+	}
+	userContent := userMsg.Get("content").Array()
+	if len(userContent) != 3 {
+		t.Fatalf("Expected 3 user content blocks, got %d. Content: %s", len(userContent), userMsg.Get("content").Raw)
+	}
+	if got := userContent[0].Get("type").String(); got != "tool_result" {
+		t.Fatalf("Expected user content[0].type %q, got %q", "tool_result", got)
+	}
+	if got := userContent[0].Get("tool_use_id").String(); got != "call_a" {
+		t.Fatalf("Expected first tool_result id %q, got %q", "call_a", got)
+	}
+	if got := userContent[1].Get("type").String(); got != "tool_result" {
+		t.Fatalf("Expected user content[1].type %q, got %q", "tool_result", got)
+	}
+	if got := userContent[1].Get("tool_use_id").String(); got != "call_b" {
+		t.Fatalf("Expected second tool_result id %q, got %q", "call_b", got)
+	}
+	if got := userContent[2].Get("type").String(); got != "text" {
+		t.Fatalf("Expected user content[2].type %q, got %q", "text", got)
+	}
+	if got := userContent[2].Get("text").String(); got != "Now summarize." {
+		t.Fatalf("Expected trailing user text %q, got %q", "Now summarize.", got)
+	}
+}
