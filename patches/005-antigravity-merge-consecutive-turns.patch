+func TestConvertGeminiRequestToAntigravity_MergesConsecutiveSameRoleTurns(t *testing.T) {
+	inputJSON := []byte(`{
+		"model": "gemini-3-pro-preview",
+		"contents": [
+			{"role": "user", "parts": [{"text": "one"}]},
+			{"role": "user", "parts": [{"text": "two"}]},
+			{"role": "model", "parts": [{"text": "three"}]},
+			{"role": "model", "parts": [{"text": "four"}]}
+		]
+	}`)
+
+	output := ConvertGeminiRequestToAntigravity("gemini-3-pro-preview", inputJSON, false)
+	contents := gjson.GetBytes(output, "request.contents").Array()
+	if len(contents) != 2 {
+		t.Fatalf("request.contents len = %d, want 2", len(contents))
+	}
+	if got := contents[0].Get("role").String(); got != "user" {
+		t.Fatalf("request.contents.0.role = %q, want user", got)
+	}
+	if got := contents[1].Get("role").String(); got != "model" {
+		t.Fatalf("request.contents.1.role = %q, want model", got)
+	}
+	if got := len(contents[0].Get("parts").Array()); got != 2 {
+		t.Fatalf("request.contents.0.parts len = %d, want 2", got)
+	}
+	if got := len(contents[1].Get("parts").Array()); got != 2 {
+		t.Fatalf("request.contents.1.parts len = %d, want 2", got)
+	}
+}
