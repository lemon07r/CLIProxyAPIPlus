# PATCH 008: Stream tool call deltas incrementally in Claude-to-OpenAI translator
#
# Emit tool call headers at content_block_start and argument fragments at
# input_json_delta so OpenAI-compatible streaming clients can surface in-flight
# tool activity instead of waiting for content_block_stop.

diff --git a/internal/translator/claude/openai/chat-completions/claude_openai_response.go b/internal/translator/claude/openai/chat-completions/claude_openai_response.go
index 423beeba..89b74fba 100644
--- a/internal/translator/claude/openai/chat-completions/claude_openai_response.go
+++ b/internal/translator/claude/openai/chat-completions/claude_openai_response.go
@@ -125,7 +125,7 @@ func ConvertClaudeResponseToOpenAI(_ context.Context, modelName string, original
 			blockType := contentBlock.Get("type").String()
 
 			if blockType == "tool_use" {
-				// Start of tool call - initialize accumulator to track arguments
+				// Start of tool call - emit header (id + name) immediately for streaming progress
 				toolCallID := contentBlock.Get("id").String()
 				toolName := contentBlock.Get("name").String()
 				index := int(root.Get("index").Int())
@@ -139,8 +139,13 @@ func ConvertClaudeResponseToOpenAI(_ context.Context, modelName string, original
 					Name: toolName,
 				}
 
-				// Don't output anything yet - wait for complete tool call
-				return [][]byte{}
+				// Emit the tool call header so clients can show progress immediately
+				template, _ = sjson.SetBytes(template, "choices.0.delta.tool_calls.0.index", index)
+				template, _ = sjson.SetBytes(template, "choices.0.delta.tool_calls.0.id", toolCallID)
+				template, _ = sjson.SetBytes(template, "choices.0.delta.tool_calls.0.type", "function")
+				template, _ = sjson.SetBytes(template, "choices.0.delta.tool_calls.0.function.name", toolName)
+				template, _ = sjson.SetBytes(template, "choices.0.delta.tool_calls.0.function.arguments", "")
+				return [][]byte{template}
 			}
 		}
 		return [][]byte{}
@@ -165,16 +170,13 @@ func ConvertClaudeResponseToOpenAI(_ context.Context, modelName string, original
 					hasContent = true
 				}
 			case "input_json_delta":
-				// Tool use input delta - accumulate arguments for tool calls
+				// Tool use input delta - stream argument fragments incrementally
 				if partialJSON := delta.Get("partial_json"); partialJSON.Exists() {
 					index := int(root.Get("index").Int())
-					if (*param).(*ConvertAnthropicResponseToOpenAIParams).ToolCallsAccumulator != nil {
-						if accumulator, exists := (*param).(*ConvertAnthropicResponseToOpenAIParams).ToolCallsAccumulator[index]; exists {
-							accumulator.Arguments.WriteString(partialJSON.String())
-						}
-					}
+					template, _ = sjson.SetBytes(template, "choices.0.delta.tool_calls.0.index", index)
+					template, _ = sjson.SetBytes(template, "choices.0.delta.tool_calls.0.function.arguments", partialJSON.String())
+					return [][]byte{template}
 				}
-				// Don't output anything yet - wait for complete tool call
 				return [][]byte{}
 			}
 		}
@@ -185,26 +187,10 @@ func ConvertClaudeResponseToOpenAI(_ context.Context, modelName string, original
 		}
 
 	case "content_block_stop":
-		// End of content block - output complete tool call if it's a tool_use block
+		// End of content block - clean up tool call accumulator
 		index := int(root.Get("index").Int())
 		if (*param).(*ConvertAnthropicResponseToOpenAIParams).ToolCallsAccumulator != nil {
-			if accumulator, exists := (*param).(*ConvertAnthropicResponseToOpenAIParams).ToolCallsAccumulator[index]; exists {
-				// Build complete tool call with accumulated arguments
-				arguments := accumulator.Arguments.String()
-				if arguments == "" {
-					arguments = "{}"
-				}
-				template, _ = sjson.SetBytes(template, "choices.0.delta.tool_calls.0.index", index)
-				template, _ = sjson.SetBytes(template, "choices.0.delta.tool_calls.0.id", accumulator.ID)
-				template, _ = sjson.SetBytes(template, "choices.0.delta.tool_calls.0.type", "function")
-				template, _ = sjson.SetBytes(template, "choices.0.delta.tool_calls.0.function.name", accumulator.Name)
-				template, _ = sjson.SetBytes(template, "choices.0.delta.tool_calls.0.function.arguments", arguments)
-
-				// Clean up the accumulator for this index
-				delete((*param).(*ConvertAnthropicResponseToOpenAIParams).ToolCallsAccumulator, index)
-
-				return [][]byte{template}
-			}
+			delete((*param).(*ConvertAnthropicResponseToOpenAIParams).ToolCallsAccumulator, index)
 		}
 		return [][]byte{}
 
diff --git a/internal/translator/claude/openai/chat-completions/claude_openai_response_test.go b/internal/translator/claude/openai/chat-completions/claude_openai_response_test.go
index 7bd6eb1f..3348fcd2 100644
--- a/internal/translator/claude/openai/chat-completions/claude_openai_response_test.go
+++ b/internal/translator/claude/openai/chat-completions/claude_openai_response_test.go
@@ -56,3 +56,43 @@ func TestConvertClaudeResponseToOpenAINonStream_UsageIncludesCachedTokens(t *tes
 		t.Fatalf("expected cached_tokens %d, got %d", 22000, gotCachedTokens)
 	}
 }
+
+func TestConvertClaudeResponseToOpenAI_StreamsToolCallHeaderImmediately(t *testing.T) {
+	ctx := context.Background()
+	var param any
+
+	ConvertClaudeResponseToOpenAI(ctx, "claude-opus-4-6", nil, nil, []byte(`data: {"type":"message_start","message":{"id":"msg_123"}}`), &param)
+	out := ConvertClaudeResponseToOpenAI(ctx, "claude-opus-4-6", nil, nil, []byte(`data: {"type":"content_block_start","index":0,"content_block":{"type":"tool_use","id":"toolu_123","name":"Write"}}`), &param)
+
+	if len(out) != 1 {
+		t.Fatalf("expected 1 chunk, got %d", len(out))
+	}
+	if got := gjson.GetBytes(out[0], "choices.0.delta.tool_calls.0.id").String(); got != "toolu_123" {
+		t.Fatalf("tool call id = %q, want toolu_123", got)
+	}
+	if got := gjson.GetBytes(out[0], "choices.0.delta.tool_calls.0.function.name").String(); got != "Write" {
+		t.Fatalf("tool call name = %q, want Write", got)
+	}
+	if got := gjson.GetBytes(out[0], "choices.0.delta.tool_calls.0.function.arguments").String(); got != "" {
+		t.Fatalf("tool call arguments = %q, want empty string", got)
+	}
+}
+
+func TestConvertClaudeResponseToOpenAI_StreamsToolCallArgumentDeltas(t *testing.T) {
+	ctx := context.Background()
+	var param any
+
+	ConvertClaudeResponseToOpenAI(ctx, "claude-opus-4-6", nil, nil, []byte(`data: {"type":"message_start","message":{"id":"msg_123"}}`), &param)
+	ConvertClaudeResponseToOpenAI(ctx, "claude-opus-4-6", nil, nil, []byte(`data: {"type":"content_block_start","index":0,"content_block":{"type":"tool_use","id":"toolu_123","name":"Write"}}`), &param)
+	out := ConvertClaudeResponseToOpenAI(ctx, "claude-opus-4-6", nil, nil, []byte(`data: {"type":"content_block_delta","index":0,"delta":{"type":"input_json_delta","partial_json":"{\"path\":\"/tmp/x\"}"}}`), &param)
+
+	if len(out) != 1 {
+		t.Fatalf("expected 1 chunk, got %d", len(out))
+	}
+	if got := gjson.GetBytes(out[0], "choices.0.delta.tool_calls.0.index").Int(); got != 0 {
+		t.Fatalf("tool call index = %d, want 0", got)
+	}
+	if got := gjson.GetBytes(out[0], "choices.0.delta.tool_calls.0.function.arguments").String(); got != `{"path":"/tmp/x"}` {
+		t.Fatalf("tool call arguments delta = %q, want partial json", got)
+	}
+}
