+func TestApplyHeaders_XInitiator_ConcurrentColdSessionUsesSingleUser(t *testing.T) {
+	t.Parallel()
+	e := &GitHubCopilotExecutor{
+		warmConversations:    make(map[string]time.Time),
+		warmingConversations: make(map[string]time.Time),
+	}
+	opts := cliproxyexecutor.Options{
+		Headers: http.Header{
+			copilotWarmConversationSessionHeader: []string{"affinity-123"},
+		},
+	}
+	titleBody := []byte(`{"messages":[{"role":"user","content":"Generate a title for this conversation:\nReview PR 1 and fix valid issues"}]}`)
+	mainBody := []byte(`{"messages":[{"role":"user","content":"Review PR 1 and fix valid issues"}]}`)
+
+	titleReq, _ := http.NewRequest(http.MethodPost, "https://example.com", nil)
+	e.applyHeaders(titleReq, "token", sdktranslator.FormatOpenAI, titleBody, nil, opts)
+	if got := titleReq.Header.Get("X-Initiator"); got != "user" {
+		t.Fatalf("first cold session request X-Initiator = %q, want user", got)
+	}
+
+	mainReq, _ := http.NewRequest(http.MethodPost, "https://example.com", nil)
+	e.applyHeaders(mainReq, "token", sdktranslator.FormatOpenAI, mainBody, nil, opts)
+	if got := mainReq.Header.Get("X-Initiator"); got != "agent" {
+		t.Fatalf("concurrent cold session request X-Initiator = %q, want agent", got)
+	}
+
+	e.markCopilotWarmConversation(nil, opts, "token", titleBody)
+
+	followUpReq, _ := http.NewRequest(http.MethodPost, "https://example.com", nil)
+	followUpReq.Header.Set("X-Request-Id", findCopilotWarmConversationRequestID(t, false))
+	e.applyHeaders(followUpReq, "token", sdktranslator.FormatOpenAI, mainBody, nil, opts)
+	if got := followUpReq.Header.Get("X-Initiator"); got != "agent" {
+		t.Fatalf("warmed session follow-up X-Initiator = %q, want agent", got)
+	}
+}
