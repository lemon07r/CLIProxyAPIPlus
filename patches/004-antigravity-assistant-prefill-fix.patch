+func TestConvertGeminiRequestToAntigravity_ClaudePrefillBecomesSyntheticUser(t *testing.T) {
+	inputJSON := []byte(`{
+		"model": "claude-opus-4-6",
+		"contents": [
+			{
+				"role": "user",
+				"parts": [{"text": "Write a function"}]
+			},
+			{
+				"role": "model",
+				"parts": [{"text": "Here is the start"}]
+			}
+		]
+	}`)
+
+	output := ConvertGeminiRequestToAntigravity("claude-opus-4-6", inputJSON, false)
+	if got := gjson.GetBytes(output, "request.contents.1.role").String(); got != "user" {
+		t.Fatalf("request.contents.1.role = %q, want user", got)
+	}
+	if got := gjson.GetBytes(output, "request.contents.1.parts.0.text").String(); got != "Continue from: Here is the start" {
+		t.Fatalf("request.contents.1.parts.0.text = %q, want continuation hint", got)
+	}
+}
+
+func TestConvertGeminiRequestToAntigravity_ClaudeThinkingTailDoesNotBecomeSyntheticUser(t *testing.T) {
+	inputJSON := []byte(`{
+		"model": "claude-opus-4-6",
+		"contents": [
+			{
+				"role": "user",
+				"parts": [{"text": "Solve it"}]
+			},
+			{
+				"role": "model",
+				"parts": [
+					{"text": "internal", "thought": true, "thoughtSignature": "sig"},
+					{"text": "Answer"}
+				]
+			}
+		]
+	}`)
+
+	output := ConvertGeminiRequestToAntigravity("claude-opus-4-6", inputJSON, false)
+	if got := gjson.GetBytes(output, "request.contents.1.role").String(); got != "model" {
+		t.Fatalf("request.contents.1.role = %q, want model", got)
+	}
+	if got := gjson.GetBytes(output, "request.contents.1.parts.0.text").String(); got != "Answer" {
+		t.Fatalf("request.contents.1.parts.0.text = %q, want Answer", got)
+	}
+}
+
 func TestFixCLIToolResponse_PreservesFunctionResponseParts(t *testing.T) {
 	// When functionResponse contains a "parts" field with inlineData (from Claude
 	// translator's image embedding), fixCLIToolResponse should preserve it as-is.
