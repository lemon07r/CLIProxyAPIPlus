# PATCH 004: Handle assistant prefill for Claude models via Antigravity Gemini translator
#
# Some Claude-model requests routed through the Antigravity Gemini translator end with
# a trailing model text turn used as assistant prefill. That shape can be rejected by
# the upstream backend, so rewrite only that narrow case into a synthetic user
# continuation hint.
#
# This is intentionally NOT applied to the Claude-to-Antigravity translator: plain
# trailing assistant history there is preserved to avoid rewriting normal assistant
# turns and thinking blocks.

diff --git a/internal/translator/antigravity/gemini/antigravity_gemini_request.go b/internal/translator/antigravity/gemini/antigravity_gemini_request.go
index 196cccd8..034809b6 100644
--- a/internal/translator/antigravity/gemini/antigravity_gemini_request.go
+++ b/internal/translator/antigravity/gemini/antigravity_gemini_request.go
@@ -80,6 +80,38 @@ func ConvertGeminiRequestToAntigravity(modelName string, inputRawJSON []byte, _
 		})
 	}
 
+	claudePrefillText := ""
+	if strings.Contains(modelName, "claude") {
+		contents = gjson.GetBytes(rawJSON, "request.contents")
+		if contents.Exists() && contents.IsArray() {
+			contentsArray := contents.Array()
+			if len(contentsArray) > 0 {
+				lastContent := contentsArray[len(contentsArray)-1]
+				if lastContent.Get("role").String() == "model" {
+					hasFunctionCall := false
+					hasThought := false
+					var prefillTexts []string
+					lastContent.Get("parts").ForEach(func(_, part gjson.Result) bool {
+						if part.Get("functionCall").Exists() {
+							hasFunctionCall = true
+							return false
+						}
+						if part.Get("thought").Bool() {
+							hasThought = true
+						}
+						if t := part.Get("text").String(); t != "" {
+							prefillTexts = append(prefillTexts, t)
+						}
+						return true
+					})
+					if !hasFunctionCall && !hasThought && len(prefillTexts) > 0 {
+						claudePrefillText = strings.Join(prefillTexts, "")
+					}
+				}
+			}
+		}
+	}
+
 	toolsResult := gjson.GetBytes(rawJSON, "request.tools")
 	if toolsResult.Exists() && toolsResult.IsArray() {
 		toolResults := toolsResult.Array()
@@ -149,6 +181,27 @@ func ConvertGeminiRequestToAntigravity(modelName string, inputRawJSON []byte, _
 		})
 	}
 
+	// Handle assistant prefill for Claude models routed via the Gemini translator
+	if claudePrefillText != "" {
+		contents = gjson.GetBytes(rawJSON, "request.contents")
+		if contents.Exists() && contents.IsArray() {
+			contentsArray := contents.Array()
+			if len(contentsArray) > 0 {
+				lastContent := contentsArray[len(contentsArray)-1]
+				if lastContent.Get("role").String() == "model" {
+					lastIdx := len(contentsArray) - 1
+					rawJSON, _ = sjson.DeleteBytes(rawJSON, fmt.Sprintf("request.contents.%d", lastIdx))
+
+					syntheticUser := `{"role":"user","parts":[]}`
+					partJSON := `{}`
+					partJSON, _ = sjson.Set(partJSON, "text", "Continue from: "+claudePrefillText)
+					syntheticUser, _ = sjson.SetRaw(syntheticUser, "parts.-1", partJSON)
+					rawJSON, _ = sjson.SetRawBytes(rawJSON, "request.contents.-1", []byte(syntheticUser))
+				}
+			}
+		}
+	}
+
 	return common.AttachDefaultSafetySettings(rawJSON, "request.safetySettings")
 }
 
